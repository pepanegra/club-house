# Copia este archivo como .env y llena los valores
# cp .env.example .env

# Django
SECRET_KEY=django-insecure-cambia-esto-por-una-clave-larga-y-segura
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — dominios del frontend que pueden hacer peticiones al API
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# Base de datos (solo necesario en producción, Railway la provee)
# DATABASE_URL=postgresql://usuario:password@host:5432/clubhouse_db

# Cloudinary (para subir fotos en producción)
# CLOUDINARY_CLOUD_NAME=tu-cloud-name
# CLOUDINARY_API_KEY=tu-api-key
# CLOUDINARY_API_SECRET=tu-api-secret
